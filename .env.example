# Telegram IT BOT — 環境變數範本
# 使用方式：複製為 .env 後填入真實值（勿將 .env 提交至 Git）
# cp .env.example .env   （Windows: copy .env.example .env）

# 後台登入（必填）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=請改為強密碼
JWT_SECRET=請改為長隨機字串_例如_openssl_rand_hex_32

# HTTP 服務埠（請與主機面板配發或本機開放埠一致，例如 3000、8080）
PORT=3000

# Telegram Bot Token（啟動必填；亦可之後在後台寫入 DB，改完請重啟程序）
BOT_TOKEN=請填入_BotFather_核發的_Token

# SQLite 檔案路徑（相對專案根目錄或絕對路徑）
DATABASE_PATH=./data/app.db

# 選填：/safe 指令用 Google Safe Browsing API Key（後台設定會覆寫 DB）
# GOOGLE_SAFE_BROWSING_API_KEY=

# 選填：記憶體極小主機可限制 V8 堆積，避免 OOM（數值請依主機調整）
# NODE_OPTIONS=--max-old-space-size=400
